---
config:
  layout: elk
---
flowchart TB
  User(("Business<br/>User"))

  subgraph DataPrep["Data Preparation"]
    direction LR
    Kaggle["Kaggle CSVs<br/>(Olist · 9 tables)"]
    Ingest["ingest_data.py"]
    BuildMeta["build_metadata.py"]
  end

  subgraph Snowflake["Snowflake Data Cloud"]
    direction TB
    RAW[("RAW Schema<br/>9 tables · ~100k rows")]
    Meta[("METADATA Schema<br/>TABLE_DESCRIPTIONS")]
    CortexSearch["Cortex Search Service"]
    CortexLLM["CORTEX.COMPLETE<br/>llama3.1-70b"]
    SQLExec["SQL Engine<br/>EXPLAIN + Execute"]
  end

  subgraph DomainAdapt["Domain Adaptation — Lab 8"]
    direction LR
    Dataset["Instruction Dataset<br/>82 Alpaca examples"]
    LoRA["LoRA Fine-tuning<br/>CodeLlama-7B · QLoRA 4-bit"]
    APIServer["FastAPI Model Server<br/>api_server.py"]
  end

  subgraph Agents["AI Agent Reasoning Layer"]
    direction TB
    SL["Schema Linker<br/>Cortex Search RAG<br/>FK-partner supplementation"]
    SG["SQL Generator<br/>Structured prompt · few-shot"]
    V["Validator<br/>EXPLAIN · self-correction<br/>3 retries"]
    Trace["PipelineTrace<br/>Per-agent timing"]
  end

  subgraph App["Streamlit Application"]
    direction LR
    Chat["Chat Tab<br/>Query · SQL · Results · Viz"]
    Monitor["Monitor Tab<br/>Latency · Success rate"]
  end

  Kaggle --> Ingest --> RAW
  RAW --> BuildMeta --> Meta --> CortexSearch

  Dataset --> LoRA --> APIServer

  User <--> Chat
  User -.-> Monitor

  Chat --> SL
  SL <-- "semantic search" --> CortexSearch
  SL -- "schema context" --> SG
  SG <-- "CORTEX.COMPLETE" --> CortexLLM
  APIServer -. "alt inference" .-> SG
  SG --> V
  V <-- "EXPLAIN / Execute" --> SQLExec
  SQLExec <--> RAW
  V -- "error feedback" --> SG
  V --> Trace
  Trace --> Chat & Monitor

  Kaggle:::source
  Ingest:::prep
  BuildMeta:::prep
  RAW:::snow
  Meta:::snow
  CortexSearch:::snow
  CortexLLM:::snow
  SQLExec:::snow
  Dataset:::adapt
  LoRA:::adapt
  APIServer:::adapt
  SL:::agent
  SG:::agent
  V:::agent
  Trace:::agent
  Chat:::ui
  Monitor:::ui
  User:::user

